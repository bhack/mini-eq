include AGENTS.md
include CHANGELOG.md
include SECURITY.md
include io.github.bhack.mini-eq.yaml
include python3-dependencies.yaml
include src/mini_eq/style.css
include src/mini_eq/assets/icons/hicolor/scalable/apps/*.svg
include src/mini_eq/assets/icons/hicolor/symbolic/apps/*.svg
include data/*.desktop
include data/*.metainfo.xml
include docs/flathub.md
include docs/performance.md
include docs/release.md
include docs/social-preview.png
include docs/screenshots/README.md
include docs/screenshots/*.png
include docker/*.Dockerfile
include extensions/gnome-shell/README.md
recursive-include extensions/gnome-shell/mini-eq@bhack.github.io *
include flatpak/patches/*.patch
include tools/*.py
include tools/*.sh
recursive-include tools/gnome-shell-extension *.py
